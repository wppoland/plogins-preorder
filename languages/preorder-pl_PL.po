#. Plugin Name of the plugin
#: preorder.php
msgid "Preorder - Pre-Orders for WooCommerce"
msgstr "Preorder - Przedsprzedaż dla WooCommerce"

#. Plugin URI of the plugin
#: preorder.php
msgid "https://plogins.com/preorder/"
msgstr "https://plogins.com/preorder/"

#. Description of the plugin
#: preorder.php
msgid "Let customers pre-order upcoming or out-of-stock WooCommerce products with a custom add-to-cart button."
msgstr "Pozwól klientom zamawiać w przedsprzedaży nadchodzące lub niedostępne produkty WooCommerce dzięki niestandardowemu przyciskowi dodawania do koszyka."

#. Author of the plugin
#: preorder.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: preorder.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: preorder.php:46
msgid "Preorder - Pre-Orders for WooCommerce requires WooCommerce to be active."
msgstr "Preorder - Przedsprzedaż dla WooCommerce wymaga aktywnego WooCommerce."

#: src/Admin/ProductDataPanel.php:32
#: src/Service/PreorderService.php:148
#: src/Service/PreorderService.php:170
msgid "Pre-order"
msgstr "Przedsprzedaż"

#: src/Admin/ProductDataPanel.php:33
msgid "Sell this product as a pre-order. It stays purchasable even when out of stock."
msgstr "Sprzedawaj ten produkt w przedsprzedaży. Pozostaje dostępny do kupienia nawet po wyczerpaniu zapasów."

#: src/Admin/Settings.php:45
#: src/Admin/Settings.php:46
#: src/Admin/Settings.php:99
msgid "Pre-orders"
msgstr "Przedsprzedaż"

#: src/Admin/Settings.php:64
msgid "Settings"
msgstr "Ustawienia"

#: src/Admin/Settings.php:103
msgid "Settings saved."
msgstr "Ustawienia zostały zapisane."

#: src/Admin/Settings.php:108
msgid "Mark individual products as pre-orders from the product editor (Product data → General). These options control the storefront defaults."
msgstr "Oznaczaj poszczególne produkty jako dostępne w przedsprzedaży w edytorze produktu (Dane produktu → Ogólne). Te opcje sterują domyślnymi ustawieniami sklepu."

#: src/Admin/Settings.php:119
msgid "Enable pre-orders"
msgstr "Włącz przedsprzedaż"

#: src/Admin/Settings.php:131
msgid "Apply pre-order behaviour on the storefront."
msgstr "Stosuj zachowanie przedsprzedaży w sklepie."

#: src/Admin/Settings.php:134
msgid "When off, products flagged as pre-orders behave like normal products. Turn this off to pause pre-orders store-wide without editing each product."
msgstr "Po wyłączeniu produkty oznaczone jako przedsprzedaż zachowują się jak zwykłe produkty. Wyłącz tę opcję, aby wstrzymać przedsprzedaż w całym sklepie bez edytowania każdego produktu."

#: src/Admin/Settings.php:140
msgid "Default button text"
msgstr "Domyślny tekst przycisku"

#: src/Admin/Settings.php:149
#: src/Settings.php:50
msgid "Pre-order now"
msgstr "Zamów w przedsprzedaży"

#: src/Admin/Settings.php:153
msgid "Add-to-cart label shown for pre-order products. Individual products can override this in the product editor."
msgstr "Etykieta przycisku dodawania do koszyka wyświetlana dla produktów w przedsprzedaży. Poszczególne produkty mogą ją nadpisać w edytorze produktu."

#: src/Admin/Settings.php:160
msgid "Save changes"
msgstr "Zapisz zmiany"

#: src/Admin/Settings.php:169
msgid "You do not have permission to manage these settings."
msgstr "Nie masz uprawnień do zarządzania tymi ustawieniami."

#: src/Service/PreorderService.php:149
#: src/Service/PreorderService.php:170
msgid "Yes"
msgstr "Tak"
